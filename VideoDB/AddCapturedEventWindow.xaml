<Window x:Class="VideoDB.AddCapturedEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Scene Metadata"
        Height="520"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="14" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="86"/>
                <ColumnDefinition Width="318"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Video ID" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="VideoIdBox" Height="28" Margin="0,0,0,8" IsReadOnly="True"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Time" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TimeBox" Width="120" Height="28" HorizontalAlignment="Left" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tags" VerticalAlignment="Top" Margin="0,4,8,8"/>
            <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox x:Name="TagBox" Width="220" Height="28" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,8,0"/>
                    <Button Content="Add" Width="70" Height="28" Click="AddTagButton_Click"/>
                </StackPanel>
                <ItemsControl x:Name="TagChipItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="2" Padding="8,3" Click="RemoveTagButton_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Actresses" VerticalAlignment="Top" Margin="0,4,8,8"/>
            <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox x:Name="ActressBox" Width="220" Height="28" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,8,0"/>
                    <Button Content="Add" Width="70" Height="28" Click="AddActressButton_Click"/>
                </StackPanel>
                <ItemsControl x:Name="ActressChipItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="2" Padding="8,3" Click="RemoveActressButton_Click"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Rating" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="RatingBox" Width="90" Height="28" HorizontalAlignment="Left" Margin="0,0,0,8" SelectedIndex="2">
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
                <ComboBoxItem Content="4"/>
                <ComboBoxItem Content="5"/>
            </ComboBox>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Note" VerticalAlignment="Top" Margin="0,4,8,8"/>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="NoteBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>

            <Border Grid.Row="2"
                    Grid.RowSpan="3"
                    Grid.Column="3"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Recent Tags"
                               FontFamily="Segoe UI Semibold"
                               Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentTagItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Margin="2"
                                            Padding="8,3"
                                            Click="RecentTagButton_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="5"
                    Grid.Column="3"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Recent Actresses"
                               FontFamily="Segoe UI Semibold"
                               Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentActressItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Margin="2"
                                            Padding="8,3"
                                            Click="RecentActressButton_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="6" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Width="90" Height="30" Margin="0,0,8,0" IsDefault="True" Click="SaveButton_Click"/>
                <Button Content="Cancel" Width="90" Height="30" IsCancel="True"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Existing Scenes"
                           FontFamily="Segoe UI Semibold"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="NoExistingScenesTextBlock"
                           DockPanel.Dock="Top"
                           Text="No scenes for this Video ID yet."
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,2,0,0"
                           Visibility="Collapsed"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ExistingSceneItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <Border Height="94"
                                                CornerRadius="6"
                                                Background="{DynamicResource InputBackgroundBrush}"
                                                ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailPath}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <TextBlock Text="{Binding Time}"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Segoe UI Semibold"
                                                   Margin="0,7,0,5"/>
                                        <ItemsControl ItemsSource="{Binding Tags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel HorizontalAlignment="Center"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource InputBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="7"
                                                            Padding="7,3"
                                                            Margin="2">
                                                        <TextBlock Text="{Binding}"
                                                                   FontFamily="Segoe UI Semibold"
                                                                   FontSize="11"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
