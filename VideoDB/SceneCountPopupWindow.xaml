<Window x:Class="VideoDB.SceneCountPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="620"
        Height="252"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Padding="12"
            Background="#E6000000"
            BorderBrush="{DynamicResource SelectionBrush}"
            BorderThickness="2"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="42"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
                <TextBlock Text="MEDIA TOOL"
                           VerticalAlignment="Center"
                           Foreground="#BDBDBD"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                <Button x:Name="CloseButton"
                        Content="X"
                        Width="26"
                        Height="24"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="RECORDED SCENES"
                           HorizontalAlignment="Center"
                           Foreground="#BDBDBD"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="NumberTextBlock"
                           Text="-"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           FontSize="50"
                           FontWeight="Bold"
                           LineHeight="58"/>
                <TextBlock x:Name="DetailTextBlock"
                           Text="Hold Scenes to check"
                           HorizontalAlignment="Center"
                           Foreground="#D0D0D0"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Capture"
                        Height="34"
                        Click="CaptureButton_Click"/>
                <Button Grid.Column="2"
                        Content="Scenes"
                        Height="34"
                        PreviewMouseLeftButtonDown="SceneCountButton_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="SceneCountButton_PreviewMouseLeftButtonUp"
                        MouseLeave="SceneCountButton_MouseLeave"/>
            </Grid>

            <Grid Grid.Row="3" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="PlaybackStatusTextBlock"
                           Text="No playback position saved"
                           Foreground="#D0D0D0"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <UniformGrid Grid.Row="1" Columns="10">
                    <Button Content="Mark" Margin="1" ToolTip="Remember current playback position" Click="RememberPositionButton_Click"/>
                    <Button Content="Back" Margin="1" ToolTip="Return to remembered playback position" Click="ReturnToPositionButton_Click"/>
                    <Button Content="-30" Margin="1" ToolTip="Seek backward 30 seconds" Tag="-30" Click="SeekButton_Click"/>
                    <Button Content="-10" Margin="1" ToolTip="Seek backward 10 seconds" Tag="-10" Click="SeekButton_Click"/>
                    <Button Content="-3" Margin="1" ToolTip="Seek backward 3 seconds" Tag="-3" Click="SeekButton_Click"/>
                    <Button Content="-1" Margin="1" ToolTip="Seek backward 1 second" Tag="-1" Click="SeekButton_Click"/>
                    <Button Content="+1" Margin="1" ToolTip="Seek forward 1 second" Tag="1" Click="SeekButton_Click"/>
                    <Button Content="+3" Margin="1" ToolTip="Seek forward 3 seconds" Tag="3" Click="SeekButton_Click"/>
                    <Button Content="+10" Margin="1" ToolTip="Seek forward 10 seconds" Tag="10" Click="SeekButton_Click"/>
                    <Button Content="+30" Margin="1" ToolTip="Seek forward 30 seconds" Tag="30" Click="SeekButton_Click"/>
                </UniformGrid>
            </Grid>
        </Grid>
    </Border>
</Window>
