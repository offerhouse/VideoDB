<Window x:Class="VideoDB.ScanLocationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scan Locations"
        Height="420"
        Width="760"
        WindowStartupLocation="CenterOwner"
        MinHeight="340"
        MinWidth="640"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <DockPanel Margin="12" Background="{DynamicResource AppBackgroundBrush}">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="92"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="86"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="MPC-HC"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                     x:Name="MpcPathBox"
                     Height="28"
                     Margin="0,0,8,0"/>
            <Button Grid.Column="2"
                    Content="Browse"
                    Height="28"
                    Click="BrowseMpcButton_Click"/>
        </Grid>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Add Folder"
                    Width="96"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="AddFolderButton_Click"/>
            <Button Content="Remove"
                    Width="86"
                    Height="30"
                    Margin="0,0,18,0"
                    Click="RemoveButton_Click"/>
            <Button Content="Save"
                    Width="86"
                    Height="30"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
            <Button Content="Cancel"
                    Width="86"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>

        <DataGrid x:Name="LocationGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Enabled"
                                        Binding="{Binding Enabled}"
                                        Width="80"/>
                <DataGridCheckBoxColumn Header="Subdirs"
                                        Binding="{Binding IncludeSubdirectories}"
                                        Width="80"/>
                <DataGridTextColumn Header="Path"
                                    Binding="{Binding Path}"
                                    Width="*"/>
                <DataGridTextColumn Header="Last Error"
                                    Binding="{Binding LastError}"
                                    Width="180"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
